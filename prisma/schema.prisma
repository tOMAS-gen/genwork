generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  SUPERADMIN
  MEMBER
  READER
}

enum AccessMode {
  DOMAIN
  LIST
}

enum StorageProviderKind {
  NEXTCLOUD
  GDRIVE
}

enum GroupRole {
  ADMIN
  MEMBER
}

enum WorkStatus {
  ACTIVE
  ARCHIVED
}

enum TaskStatusType {
  IN_PROGRESS
  FINAL
}

enum LinkType {
  EXEC
  REF
}

enum LinkTargetType {
  SECTOR
  USER
}

enum ArchiveStatus {
  BUILDING
  READY
  CONFIRMED
  FAILED
}

enum JobKind {
  CREATE_USER
  CREATE_GROUP_FOLDER
  ADD_MEMBER
  REMOVE_MEMBER
  CREATE_WORK_FOLDER
  DELETE_WORK_FOLDER
  MOVE_WORK_FOLDER
  RENAME_WORK_FOLDER
}

enum JobStatus {
  PENDING
  DONE
  FAILED
}

enum TaskOrigin {
  WORK
  SECTOR
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  name            String
  image           String?
  globalRole      GlobalRole @default(MEMBER)
  nextcloudUserId String?
  createdAt       DateTime   @default(now())

  memberships        GroupMembership[]
  ownedGroups        Group[]            @relation("GroupOwner")
  sectorGrants       SectorGrant[]
  readerGrants       ReaderGrant[]
  ownedWorks         Work[]             @relation("WorkOwner")
  createdWorks       Work[]             @relation("WorkCreator")
  createdTasks       Task[]             @relation("TaskCreator")
  completedTasks     Task[]             @relation("TaskCompleter")
  lastEditedTasks    Task[]             @relation("TaskLastEditor")
  statusChangedTasks Task[]             @relation("TaskStatusChanger")
  taskStatuses       TaskStatus[]       @relation("PersonalTaskStatuses")
  taskStatusChanges  TaskStatusChange[]
  taskRefs           TaskLink[]         @relation("LinkUser")
  attachments        Attachment[]
  archives           ArchiveRecord[]
  labelKeys          LabelKey[]         @relation("LabelKeyOwner")
  favorites          UserFavorite[]
  notes              Note[]
  personalStages     ProjectStage[]     @relation("PersonalStages")
  mcpConnections     McpConnection[]
  reminders          Reminder[]         @relation("ReminderOwner")
  createdReminders   Reminder[]         @relation("ReminderCreator")
  reminderDeliveries ReminderDelivery[]
  errorLogs          ErrorLog[]
}

model AccessConfig {
  id                  Int                 @id @default(1)
  mode                AccessMode          @default(LIST)
  domain              String?
  storageProvider     StorageProviderKind @default(NEXTCLOUD)
  storageConfig       Json?
  // Recordatorios: zona horaria única del sistema (R4) y config de email cifrada (R5).
  timezone            String              @default("America/Argentina/Buenos_Aires")
  reminderEmailConfig Json?
  updatedAt           DateTime            @updatedAt
}

model AllowedEmail {
  email     String   @id
  createdAt DateTime @default(now())
}

model Group {
  id                String   @id @default(uuid())
  name              String   @unique
  ownerId           String
  owner             User     @relation("GroupOwner", fields: [ownerId], references: [id])
  publicRead        Boolean  @default(false)
  color             String?
  nextcloudGroupId  String?
  nextcloudFolderId String?
  createdAt         DateTime @default(now())

  memberships  GroupMembership[]
  works        Work[]
  readerGrants ReaderGrant[]
  labelKeys    LabelKey[]
  stages       ProjectStage[]
  reminders    Reminder[]
  taskStatuses TaskStatus[]
}

model GroupMembership {
  userId  String
  groupId String
  role    GroupRole @default(MEMBER)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Sector {
  id    String  @id @default(uuid())
  name  String
  color String?

  grants       SectorGrant[]
  taskLinks    TaskLink[]
  homeTasks    Task[]        @relation("TaskHomeSector")
  originTasks  Task[]        @relation("TaskOriginSector")
  taskStatuses TaskStatus[]

  // Catálogo global (feature 044): nombre único a nivel organización, sin scope de grupo/personal
  @@unique([name])
}

model SectorGrant {
  userId   String
  sectorId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sector   Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@id([userId, sectorId])
}

model ReaderGrant {
  userId  String
  groupId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Work {
  id                  String     @id @default(uuid())
  name                String
  description         String?
  groupId             String?
  ownerId             String?
  status              WorkStatus @default(ACTIVE)
  isTemplate          Boolean    @default(false)
  dueDate             DateTime?
  folderSeq           Int        @default(autoincrement())
  nextcloudFolderPath String?
  createdById         String
  createdAt           DateTime   @default(now())

  stageId String?

  group       Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  owner       User?            @relation("WorkOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("WorkCreator", fields: [createdById], references: [id])
  stage       ProjectStage?    @relation(fields: [stageId], references: [id], onDelete: SetNull)
  doc         DocPage?
  tasks       Task[]
  attachments Attachment[]
  archive     ArchiveRecord?
  labels      WorkLabel[]
  favorites   UserFavorite[]
  mcpActivity McpActivityLog[]

  @@unique([groupId, name])
  @@unique([ownerId, name])
}

model DocPage {
  workId    String   @id
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  content   Json?
  updatedAt DateTime @updatedAt
}

model Task {
  id                String    @id @default(uuid())
  rawText           String
  displayText       String
  statusId          String
  statusChangedAt   DateTime?
  statusChangedById String?
  workId            String?
  sectorId          String?
  creatorId         String
  completedAt       DateTime?
  completedById     String?
  createdAt         DateTime  @default(now())

  dueDate DateTime?

  originType     TaskOrigin @default(WORK)
  originSectorId String?
  adoptedAt      DateTime?
  lastEditedById String?
  lastEditedAt   DateTime?
  description    String?
  position       Int        @default(0)

  work            Work?              @relation(fields: [workId], references: [id], onDelete: Cascade)
  homeSector      Sector?            @relation("TaskHomeSector", fields: [sectorId], references: [id], onDelete: Cascade)
  originSector    Sector?            @relation("TaskOriginSector", fields: [originSectorId], references: [id], onDelete: SetNull)
  creator         User               @relation("TaskCreator", fields: [creatorId], references: [id])
  completedBy     User?              @relation("TaskCompleter", fields: [completedById], references: [id])
  lastEditedBy    User?              @relation("TaskLastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  status          TaskStatus         @relation(fields: [statusId], references: [id], onDelete: Restrict)
  statusChangedBy User?              @relation("TaskStatusChanger", fields: [statusChangedById], references: [id], onDelete: SetNull)
  links           TaskLink[]
  labels          TaskLabel[]
  statusChanges   TaskStatusChange[]

  @@index([workId, position])
  @@index([statusId])
}

/// Historial de transiciones de estado de una tarea (feature 042, US4). Los FKs a
/// TaskStatus son SetNull (no Cascade): si un estado se elimina más adelante, el
/// historial se conserva (pierde la referencia puntual, no la fila).
model TaskStatusChange {
  id           String   @id @default(uuid())
  taskId       String
  fromStatusId String?
  toStatusId   String?
  changedById  String?
  changedAt    DateTime @default(now())

  task       Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromStatus TaskStatus? @relation("StatusChangeFrom", fields: [fromStatusId], references: [id], onDelete: SetNull)
  toStatus   TaskStatus? @relation("StatusChangeTo", fields: [toStatusId], references: [id], onDelete: SetNull)
  changedBy  User?       @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([taskId, changedAt])
}

/// Estado configurable de tarea (feature 042). Vive en un conjunto: el default de
/// grupo/personal (groupId/ownerId, igual patrón que Sector), o el override de un
/// sector puntual (sectorId). Exactamente uno de los tres scopes es no-nulo.
/// Invariantes (validados en la capa de servicio, no en DB): nombre único dentro
/// del conjunto, y exactamente un estado type=FINAL por conjunto.
model TaskStatus {
  id        String         @id @default(uuid())
  name      String
  color     String
  type      TaskStatusType
  sortOrder Int            @default(0)
  groupId   String?
  ownerId   String?
  sectorId  String?
  createdAt DateTime       @default(now())

  group       Group?             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  owner       User?              @relation("PersonalTaskStatuses", fields: [ownerId], references: [id], onDelete: Cascade)
  sector      Sector?            @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  tasks       Task[]
  fromChanges TaskStatusChange[] @relation("StatusChangeFrom")
  toChanges   TaskStatusChange[] @relation("StatusChangeTo")

  @@unique([groupId, name])
  @@unique([ownerId, name])
  @@unique([sectorId, name])
}

model TaskLink {
  taskId     String
  type       LinkType
  targetType LinkTargetType
  targetId   String
  // FKs opcionales según targetType (EXEC solo SECTOR; REF admite SECTOR o USER)
  sectorId   String?
  userId     String?

  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sector Sector? @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  user   User?   @relation("LinkUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, type, targetType, targetId])
  @@index([sectorId, type])
  @@index([userId, type])
}

model Attachment {
  id            String   @id @default(uuid())
  workId        String
  fileName      String
  mimeType      String
  size          Int
  nextcloudPath String
  uploadedById  String
  createdAt     DateTime @default(now())

  work       Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])
}

model ArchiveRecord {
  workId       String        @id
  work         Work          @relation(fields: [workId], references: [id], onDelete: Cascade)
  packagePath  String?
  status       ArchiveStatus @default(BUILDING)
  manifest     Json?
  error        String?
  archivedById String
  archivedBy   User          @relation(fields: [archivedById], references: [id])
  archivedAt   DateTime?
  createdAt    DateTime      @default(now())
}

model ProvisioningJob {
  id        String    @id @default(uuid())
  kind      JobKind
  payload   Json
  status    JobStatus @default(PENDING)
  attempts  Int       @default(0)
  lastError String?
  runAfter  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, runAfter])
}

model LabelKey {
  id      String  @id @default(uuid())
  name    String
  groupId String?
  ownerId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  owner   User?   @relation("LabelKeyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  values     LabelValue[]
  workLabels WorkLabel[]
  taskLabels TaskLabel[]

  // Unicidad por ámbito (tres niveles posibles):
  // - Global: groupId=null, ownerId=null
  // - Grupo: groupId=X, ownerId=null
  // - Personal: groupId=null, ownerId=U
  @@unique([groupId, name])
  @@unique([ownerId, name])
}

model LabelValue {
  id    String   @id @default(uuid())
  keyId String
  name  String
  color String
  key   LabelKey @relation(fields: [keyId], references: [id], onDelete: Cascade)

  workLabels WorkLabel[]
  taskLabels TaskLabel[]

  @@unique([keyId, name])
}

model WorkLabel {
  workId  String
  keyId   String
  valueId String
  work    Work       @relation(fields: [workId], references: [id], onDelete: Cascade)
  key     LabelKey   @relation(fields: [keyId], references: [id], onDelete: Cascade)
  value   LabelValue @relation(fields: [valueId], references: [id], onDelete: Cascade)

  @@id([workId, keyId])
}

model TaskLabel {
  taskId  String
  keyId   String
  valueId String
  task    Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  key     LabelKey   @relation(fields: [keyId], references: [id], onDelete: Cascade)
  value   LabelValue @relation(fields: [valueId], references: [id], onDelete: Cascade)

  @@id([taskId, keyId])
}

model UserFavorite {
  userId String
  workId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  work   Work   @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@id([userId, workId])
}

model ProjectStage {
  id        String  @id @default(uuid())
  name      String
  color     String?
  sortOrder Int     @default(0)
  groupId   String?
  ownerId   String?
  group     Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  owner     User?   @relation("PersonalStages", fields: [ownerId], references: [id], onDelete: Cascade)
  works     Work[]

  @@unique([groupId, name])
  @@unique([ownerId, name])
}

model Note {
  id        String   @id @default(uuid())
  title     String   @default("")
  content   Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
}

// ─── Recordatorios con calendario (feature 036) ──────────────────────────────

enum ReminderScope {
  INDIVIDUAL
  GROUP
  GLOBAL
}

enum RecurrenceType {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  EVERY_N
}

enum EveryUnit {
  DAY
  WEEK
  MONTH
}

// Nombrado ReminderLinkKind para no colisionar con LinkTargetType {SECTOR,USER}.
enum ReminderLinkKind {
  WORK
  SECTOR
  TASK
}

enum DeliveryStatus {
  PENDING
  DISMISSED
  SNOOZED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model Reminder {
  id          String        @id @default(uuid())
  title       String
  description String?
  scope       ReminderScope
  ownerId     String? // set en INDIVIDUAL
  groupId     String? // set en GROUP
  createdById String

  date           DateTime // fecha local de la ocurrencia base (en tz del sistema)
  recurrenceType RecurrenceType @default(ONCE)
  weekdays       Int[] // solo WEEKLY (0=lun..6=dom)
  everyN         Int? // solo EVERY_N
  everyUnit      EveryUnit? // solo EVERY_N
  untilDate      DateTime? // fin opcional por fecha
  maxOccurrences Int? // fin opcional por cantidad

  linkType ReminderLinkKind?
  linkId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner      User?              @relation("ReminderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  group      Group?             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy  User               @relation("ReminderCreator", fields: [createdById], references: [id])
  leads      ReminderLead[]
  deliveries ReminderDelivery[]

  @@index([scope])
  @@index([groupId])
  @@index([ownerId])
}

model ReminderLead {
  id          String @id @default(uuid())
  reminderId  String
  daysBefore  Int // 0 = mismo día
  minuteOfDay Int // 0..1439 (hora local de disparo)

  reminder   Reminder           @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  deliveries ReminderDelivery[]

  @@unique([reminderId, daysBefore, minuteOfDay])
}

model ReminderDelivery {
  id             String         @id @default(uuid())
  reminderId     String
  leadId         String
  userId         String
  occurrenceDate DateTime // fecha de la ocurrencia
  firedAt        DateTime // instante (UTC) del disparo
  status         DeliveryStatus @default(PENDING)
  snoozedUntil   DateTime?
  emailStatus    EmailStatus    @default(PENDING)
  emailError     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  reminder Reminder     @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  lead     ReminderLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Idempotencia dura: nunca dos avisos por (reminder, lead, ocurrencia, usuario).
  @@unique([reminderId, leadId, occurrenceDate, userId])
  @@index([userId, status])
  @@index([emailStatus])
}

// ─── Servidor MCP (feature 039) ──────────────────────────────────────────────

/// Vinculación explícita entre un usuario y un asistente de IA que actúa en su
/// nombre vía MCP (FR-009a). El token real nunca se persiste, solo su hash.
model McpConnection {
  id         String    @id @default(uuid())
  userId     String
  label      String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  confirmations McpConfirmation[]
  activity      McpActivityLog[]

  @@index([userId])
}

/// Pedido pendiente de confirmación de dos pasos para una acción destructiva o
/// irreversible ejecutada vía MCP (FR-012).
model McpConfirmation {
  id           String    @id @default(uuid())
  connectionId String
  kind         String
  payload      Json
  summary      String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  connection McpConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
}

/// Auditoría de acciones ejecutadas vía MCP, visible para el usuario dentro de
/// Genwork (FR-010).
model McpActivityLog {
  id           String   @id @default(uuid())
  connectionId String
  userId       String
  toolName     String
  targetType   String
  targetId     String?
  workId       String?
  summary      String
  createdAt    DateTime @default(now())

  connection McpConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  work       Work?         @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId, createdAt])
  @@index([userId, createdAt])
}

// ─── Registro de errores (feature 041) ────────────────────────────────────────

enum ErrorLogStatus {
  PENDING
  RESOLVED
}

/// Ocurrencia agrupada de un error no controlado del servidor (FR-001/FR-002).
/// Agrupada por `fingerprint` (mensaje+ruta, FR-007); nunca guarda el body/payload
/// de la request, solo identificadores/metadatos (FR-002/FR-009, /speckit-clarify).
model ErrorLog {
  id          String         @id @default(uuid())
  fingerprint String         @unique
  message     String
  stack       String?
  route       String
  method      String?
  userId      String?
  context     Json?
  status      ErrorLogStatus @default(PENDING)
  occurrences Int            @default(1)
  firstSeenAt DateTime       @default(now())
  lastSeenAt  DateTime       @default(now())
  resolvedAt  DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, lastSeenAt])
}
