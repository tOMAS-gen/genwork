generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  SUPERADMIN
  MEMBER
  READER
}

enum AccessMode {
  DOMAIN
  LIST
}

enum StorageProviderKind {
  NEXTCLOUD
  GDRIVE
}

enum GroupRole {
  ADMIN
  MEMBER
}

enum WorkStatus {
  ACTIVE
  ARCHIVED
}

enum TaskState {
  PENDING
  DONE
}

enum LinkType {
  EXEC
  REF
}

enum LinkTargetType {
  SECTOR
  USER
}

enum ArchiveStatus {
  BUILDING
  READY
  CONFIRMED
  FAILED
}

enum JobKind {
  CREATE_USER
  CREATE_GROUP_FOLDER
  ADD_MEMBER
  REMOVE_MEMBER
  CREATE_WORK_FOLDER
  DELETE_WORK_FOLDER
  MOVE_WORK_FOLDER
  RENAME_WORK_FOLDER
}

enum JobStatus {
  PENDING
  DONE
  FAILED
}

enum TaskOrigin {
  WORK
  SECTOR
}

enum LabelColor {
  RED
  ORANGE
  AMBER
  GREEN
  TEAL
  BLUE
  INDIGO
  VIOLET
  PINK
  GRAY
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  name            String
  image           String?
  globalRole      GlobalRole @default(MEMBER)
  nextcloudUserId String?
  createdAt       DateTime   @default(now())

  memberships     GroupMembership[]
  ownedGroups     Group[]           @relation("GroupOwner")
  sectorGrants    SectorGrant[]
  readerGrants    ReaderGrant[]
  ownedSectors    Sector[]          @relation("SectorOwner")
  ownedWorks      Work[]            @relation("WorkOwner")
  createdWorks    Work[]            @relation("WorkCreator")
  createdTasks    Task[]            @relation("TaskCreator")
  completedTasks  Task[]            @relation("TaskCompleter")
  lastEditedTasks Task[]            @relation("TaskLastEditor")
  taskRefs        TaskLink[]        @relation("LinkUser")
  attachments     Attachment[]
  archives        ArchiveRecord[]
  labelKeys       LabelKey[]        @relation("LabelKeyOwner")
  favorites       UserFavorite[]
  notes           Note[]
  personalStages  ProjectStage[]    @relation("PersonalStages")
}

model AccessConfig {
  id              Int                 @id @default(1)
  mode            AccessMode          @default(LIST)
  domain          String?
  storageProvider StorageProviderKind @default(NEXTCLOUD)
  storageConfig   Json?
  updatedAt       DateTime            @updatedAt
}

model AllowedEmail {
  email     String   @id
  createdAt DateTime @default(now())
}

model Group {
  id                String   @id @default(uuid())
  name              String   @unique
  ownerId           String
  owner             User     @relation("GroupOwner", fields: [ownerId], references: [id])
  publicRead        Boolean  @default(false)
  color             String?
  nextcloudGroupId  String?
  nextcloudFolderId String?
  createdAt         DateTime @default(now())

  memberships  GroupMembership[]
  sectors      Sector[]
  works        Work[]
  readerGrants ReaderGrant[]
  labelKeys    LabelKey[]
  stages       ProjectStage[]
}

model GroupMembership {
  userId  String
  groupId String
  role    GroupRole @default(MEMBER)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Sector {
  id      String      @id @default(uuid())
  name    String
  color   LabelColor?
  groupId String?
  ownerId String?
  group   Group?      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  owner   User?       @relation("SectorOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  grants      SectorGrant[]
  taskLinks   TaskLink[]
  homeTasks   Task[]        @relation("TaskHomeSector")
  originTasks Task[]        @relation("TaskOriginSector")

  // Unicidad por ámbito (FR-001): nombre único dentro del grupo o del espacio personal
  @@unique([groupId, name])
  @@unique([ownerId, name])
}

model SectorGrant {
  userId   String
  sectorId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sector   Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@id([userId, sectorId])
}

model ReaderGrant {
  userId  String
  groupId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Work {
  id                  String     @id @default(uuid())
  name                String
  description         String?
  groupId             String?
  ownerId             String?
  status              WorkStatus @default(ACTIVE)
  isTemplate          Boolean    @default(false)
  dueDate             DateTime?
  folderSeq           Int        @default(autoincrement())
  nextcloudFolderPath String?
  createdById         String
  createdAt           DateTime   @default(now())

  stageId String?

  group       Group?         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  owner       User?          @relation("WorkOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("WorkCreator", fields: [createdById], references: [id])
  stage       ProjectStage?  @relation(fields: [stageId], references: [id], onDelete: SetNull)
  doc         DocPage?
  tasks       Task[]
  attachments Attachment[]
  archive     ArchiveRecord?
  labels      WorkLabel[]
  favorites   UserFavorite[]

  @@unique([groupId, name])
  @@unique([ownerId, name])
}

model DocPage {
  workId    String   @id
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  content   Json?
  updatedAt DateTime @updatedAt
}

model Task {
  id            String    @id @default(uuid())
  rawText       String
  displayText   String
  state         TaskState @default(PENDING)
  workId        String?
  sectorId      String?
  creatorId     String
  completedAt   DateTime?
  completedById String?
  createdAt     DateTime  @default(now())

  dueDate DateTime?

  originType     TaskOrigin @default(WORK)
  originSectorId String?
  adoptedAt      DateTime?
  lastEditedById String?
  lastEditedAt   DateTime?
  description    String?
  position       Int        @default(0)

  work         Work?      @relation(fields: [workId], references: [id], onDelete: Cascade)
  homeSector   Sector?    @relation("TaskHomeSector", fields: [sectorId], references: [id], onDelete: Cascade)
  originSector Sector?    @relation("TaskOriginSector", fields: [originSectorId], references: [id], onDelete: SetNull)
  creator      User       @relation("TaskCreator", fields: [creatorId], references: [id])
  completedBy  User?      @relation("TaskCompleter", fields: [completedById], references: [id])
  lastEditedBy User?      @relation("TaskLastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  links        TaskLink[]

  @@index([workId, position])
}

model TaskLink {
  taskId     String
  type       LinkType
  targetType LinkTargetType
  targetId   String
  // FKs opcionales según targetType (EXEC solo SECTOR; REF admite SECTOR o USER)
  sectorId   String?
  userId     String?

  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sector Sector? @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  user   User?   @relation("LinkUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, type, targetType, targetId])
  @@index([sectorId, type])
  @@index([userId, type])
}

model Attachment {
  id            String   @id @default(uuid())
  workId        String
  fileName      String
  mimeType      String
  size          Int
  nextcloudPath String
  uploadedById  String
  createdAt     DateTime @default(now())

  work       Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])
}

model ArchiveRecord {
  workId       String        @id
  work         Work          @relation(fields: [workId], references: [id], onDelete: Cascade)
  packagePath  String?
  status       ArchiveStatus @default(BUILDING)
  manifest     Json?
  error        String?
  archivedById String
  archivedBy   User          @relation(fields: [archivedById], references: [id])
  archivedAt   DateTime?
  createdAt    DateTime      @default(now())
}

model ProvisioningJob {
  id        String    @id @default(uuid())
  kind      JobKind
  payload   Json
  status    JobStatus @default(PENDING)
  attempts  Int       @default(0)
  lastError String?
  runAfter  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, runAfter])
}

model LabelKey {
  id      String  @id @default(uuid())
  name    String
  groupId String?
  ownerId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  owner   User?   @relation("LabelKeyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  values     LabelValue[]
  workLabels WorkLabel[]

  // Unicidad por ámbito (mismo patrón que Sector): nombre único dentro del grupo o del espacio personal
  @@unique([groupId, name])
  @@unique([ownerId, name])
}

model LabelValue {
  id    String     @id @default(uuid())
  keyId String
  name  String
  color LabelColor
  key   LabelKey   @relation(fields: [keyId], references: [id], onDelete: Cascade)

  workLabels WorkLabel[]

  @@unique([keyId, name])
}

model WorkLabel {
  workId  String
  keyId   String
  valueId String
  work    Work       @relation(fields: [workId], references: [id], onDelete: Cascade)
  key     LabelKey   @relation(fields: [keyId], references: [id], onDelete: Cascade)
  value   LabelValue @relation(fields: [valueId], references: [id], onDelete: Cascade)

  @@id([workId, keyId])
}

model UserFavorite {
  userId String
  workId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  work   Work   @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@id([userId, workId])
}

model ProjectStage {
  id        String  @id @default(uuid())
  name      String
  color     String?
  sortOrder Int     @default(0)
  groupId   String?
  ownerId   String?
  group     Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  owner     User?   @relation("PersonalStages", fields: [ownerId], references: [id], onDelete: Cascade)
  works     Work[]

  @@unique([groupId, name])
  @@unique([ownerId, name])
}

model Note {
  id        String   @id @default(uuid())
  title     String   @default("")
  content   Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
}
