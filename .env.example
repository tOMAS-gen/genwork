# ===== genwork — variables de entorno =====
# Copiar este archivo a .env.local y completar con tus valores.

# --- Base de datos ---
DATABASE_URL=postgresql://genwork:genwork-dev@localhost:5433/genwork

# --- Autenticación (next-auth) ---
AUTH_SECRET=<generar con: openssl rand -base64 32>
AUTH_URL=http://localhost:3010
AUTH_TRUST_HOST=true

# --- Google OAuth (para login y acceso a Google Drive)
# Credenciales de Google Cloud Console > OAuth Client ID (tipo Web)
# Redirect URI: http://localhost:3010/api/auth/callback/google
# REQUERIDAS para R2 (spec 051: scope incremental de Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Desarrollo: usuarios de test sin Google (admin/miembro/lector)
# NUNCA poner true en producción.
DEV_AUTH=true

# --- Nextcloud (local o remoto)
# REQUERIDAS para R1 (spec 051: Login Flow v2) y specs 028/034
NEXTCLOUD_URL=http://localhost:8081
NEXTCLOUD_ADMIN_USER=ncadmin
NEXTCLOUD_ADMIN_PASSWORD=

# --- Cifrado de secretos en DB (AES-256-GCM)
# Generar con: openssl rand -hex 32
# Requerida para cifrar app passwords de Nextcloud y refresh tokens de Drive (spec 051)
APP_ENCRYPTION_KEY=

# --- Exportación y archivado ---
ARCHIVE_DIR=./storage/archives
