# --- Base de datos ---
POSTGRES_USER=genwork
POSTGRES_PASSWORD=cambiar-por-password-seguro

# --- Dominios (Caddy emite TLS automático si son públicos) ---
GENWORK_HOST=genwork.midominio.com
NEXTCLOUD_HOST=nube.midominio.com

# --- Auth.js / Google OAuth ---
# Crear OAuth Client ID (tipo Web) en Google Cloud Console.
# Redirect URI: https://$GENWORK_HOST/api/auth/callback/google
AUTH_SECRET=generar-con-openssl-rand-base64-32
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# --- Google Drive (opcional) ---
# Si querés usar credenciales OAuth separadas para Drive,
# configurá estas en vez de las GOOGLE_* de arriba. Si no están, se usan las de login.
# GDRIVE_CLIENT_ID=
# GDRIVE_CLIENT_SECRET=

# --- Nextcloud (cuenta admin de servicio) ---
NEXTCLOUD_ADMIN_USER=ncadmin
NEXTCLOUD_ADMIN_PASSWORD=cambiar-por-password-seguro

# --- Cifrado de secretos guardados en la DB (32 bytes hex) ---
# Generar con: openssl rand -hex 32
APP_ENCRYPTION_KEY=
